# ================================================================
# ORGANIC HYPOSOLUTIONS - ENVIRONMENT VARIABLES
# ================================================================
# For Vercel server-side deployments (if any API routes are used).
# GitHub Pages serves the static frontend — it does NOT read .env.
#
# Add these in your Vercel dashboard under Settings → Environment Variables:
#   https://vercel.com/[your-username]/[project-name]/settings/environment-variables
#
# DO NOT commit actual values to git — keep them in Vercel / GitHub Secrets only.
# ================================================================


# ================================================================
# SHOPIFY — STOREFRONT API  (FRONTEND-SAFE)
# ================================================================
# These are PUBLIC credentials. The Storefront API token grants
# read access to products/inventory and checkout-write access.
# It is safe to expose in client-side JavaScript (shopify-client.js).
#
# On the static site the token lives in shop/js/shopify-client.js.
# For Vercel server-side routes it can also be set here.
# ================================================================
SHOPIFY_DOMAIN=npmv1h-8e.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token

# ================================================================
# SHOPIFY — ADMIN API  (SERVER-ONLY — NEVER EXPOSE IN FRONTEND)
# ================================================================
# The Admin API key has full read/write access to orders, customers,
# products, and inventory. It must ONLY be used in server-side code
# (Vercel serverless functions, GitHub Actions, etc.).
#
# NEVER place this value in any file served by GitHub Pages.
# NEVER reference it in HTML, client-side JS, or product-catalog.js.
# ================================================================
SHOPIFY_ADMIN_API_KEY=your-admin-api-key

# ================================================================
# GOOGLE ANALYTICS  (FRONTEND-SAFE)
# ================================================================
# GA4 Measurement ID used in assets/js/analytics.js.
# This is a public tracking ID — safe to include in client-side code.
# The live value is hardcoded in analytics.js; this variable is here
# for documentation and for any server-side analytics integrations.
# ================================================================
GA4_MEASUREMENT_ID=G-HEKE217WEY

# ================================================================
# EMAIL / CONTACT FORM  (SERVER-ONLY)
# ================================================================
# Used by Vercel serverless functions (if configured) to send
# contact form submissions. Never expose in frontend code.
# ================================================================
CONTACT_EMAIL=ohshocl@gmail.com
EMAIL_SERVICE_API_KEY=your-email-service-key

# ================================================================
# SITE CONFIGURATION
# ================================================================
SITE_URL=https://organichyposolutions.com
NODE_ENV=production

# ================================================================
# SUMMARY: WHAT GOES WHERE
# ================================================================
#
#   Variable                     Safe for frontend?   Where it lives
#   -------------------------    ------------------   --------------------------
#   SHOPIFY_DOMAIN               YES                  product-catalog.js / shopify-client.js
#   SHOPIFY_STOREFRONT_TOKEN     YES                  shopify-client.js (public Storefront API)
#   SHOPIFY_ADMIN_API_KEY        NO  — SERVER ONLY    Vercel env / GitHub Secrets
#   GA4_MEASUREMENT_ID           YES                  analytics.js
#   CONTACT_EMAIL                NO  — SERVER ONLY    Vercel env (form handler)
#   EMAIL_SERVICE_API_KEY        NO  — SERVER ONLY    Vercel env
#   SITE_URL                     YES                  meta tags, sitemap
#   NODE_ENV                     N/A                  build config
#
# ================================================================
