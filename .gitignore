# ================================================================
# ORGANIC HYPOSOLUTIONS - .GITIGNORE
# Static site: GitHub Pages + Shopify Storefront API
# Last Updated: 2026-03-08
# ================================================================


# ================================================================
# ENVIRONMENT & SECRETS (CRITICAL)
# ================================================================
# Environment variable files — contain API keys, NEVER commit
.env
.env.*
!.env.example

# Shopify config with Storefront token (gitignored for local dev)
shop/js/shopify-config.js
shopify-config.js

# Other sensitive config
config.json
secrets.json

# SSL / signing certificates
*.pem
*.key
*.crt
*.p12
*.pfx


# ================================================================
# NODE.JS & DEPENDENCIES
# ================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock


# ================================================================
# BUILD & DEPLOYMENT ARTIFACTS
# ================================================================
# GitHub Pages build output
_site/

# Vercel
.vercel/

# Generic build outputs
build/
dist/
.cache/


# ================================================================
# DEPRECATED FILES (deleted from site, block if re-added)
# ================================================================
# Checkout pages — Shopify handles checkout via Storefront API
shop/checkout.html
shop/confirmation.html

# Old JS files replaced during migration
shop/js/cart-backup.js
shop/js/shopify-api-bridge.js
shop/js/shopify-integration.js

# Old API structure
API/
api-old/
shopify-api-old/


# ================================================================
# BACKUPS & OLD FILES
# ================================================================
Backups/
backups/
backup/
*-backup/
*.backup
*.bak
*.old
*.orig


# ================================================================
# IDE & EDITOR FILES
# ================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/


# ================================================================
# OS GENERATED FILES
# ================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini


# ================================================================
# TEMPORARY & LOG FILES
# ================================================================
*.tmp
*.temp
tmp/
temp/
logs/
*.log


# ================================================================
# LARGE MEDIA FILES (not for git — use Git LFS if needed)
# ================================================================
*.psd
*.ai
*.sketch
*.fig
*.mov
*.mp4
*.avi
*.tiff
*.bmp


# ================================================================
# TESTING & COVERAGE
# ================================================================
coverage/
.nyc_output
test-results/


# ================================================================
# IMPORTANT: FILES THAT MUST NOT BE IGNORED
# ================================================================
# templates/ — nav and footer loaded dynamically at runtime by JS.
#   If templates/ is gitignored, the site navigation breaks completely.
#   DO NOT add templates/ to this file.
#
# assets/ — CSS, JS, images served to the browser.
#   DO NOT ignore assets/ or any subdirectory of it.
#
# shop/js/product-catalog.js — single source of truth for product data.
#   DO NOT ignore this file.


# ================================================================
# WHITELIST OVERRIDES
# ================================================================
!.env.example
!.gitignore
!README.md
!package.json
